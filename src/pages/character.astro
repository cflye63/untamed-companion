				padding: 2.5rem;
				border-radius: 12px;
				margin-bottom: 2rem;
				border: 2px solid var(--earth-brown);
			}

			.section-header {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 2px solid var(--earth-brown);
			}

			.section-number {
				width: 60px;
				height: 60px;
				background: var(--amber);
				color: var(--forest-dark);
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2rem;
				font-weight: 900;
				flex-shrink: 0;
			}

			.section-header h2 {
				color: var(--amber);
				font-size: 2rem;
				margin: 0;
			}

			.section-intro {
				margin-bottom: 2rem;
				font-size: 1.1rem;
			}

			/* Overview Table */
			.race-overview {
				margin-bottom: 2rem;
			}

			.lineage-table {
				width: 100%;
				border-collapse: collapse;
				background: var(--forest-dark);
				border-radius: 6px;
				overflow: hidden;
				margin-top: 0.5rem;
				font-size: 0.85rem;
			}

			.lineage-table th,
			.lineage-table td {
				padding: 0.5rem 0.75rem;
				text-align: left;
				border-bottom: 1px solid var(--earth-brown);
			}

			.overview-table {
				width: 100%;
				border-collapse: collapse;
				background: var(--forest-dark);
				border-radius: 8px;
				overflow: hidden;
			}

			.overview-table th,
			.overview-table td {
				padding: 1rem;
				text-align: left;
				border-bottom: 1px solid var(--earth-brown);
			}

			.overview-table th {
				background: var(--moss-green);
				color: var(--amber);
				font-weight: 600;
			}

			.overview-table tr:last-child td {
				border-bottom: none;
			}

			/* Race Cards */
			.race-list {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.race-card {
				background: var(--forest-dark);
				border: 2px solid var(--earth-brown);
				border-radius: 12px;
				overflow: hidden;
			}

			.race-card[open] {
				border-color: var(--amber);
			}

			.race-card summary {
				padding: 1.5rem;
				cursor: pointer;
				list-style: none;
				transition: background 0.3s;
			}

			.race-card summary:hover {
				background: var(--moss-green);
			}

			.race-card summary::-webkit-details-marker {
				display: none;
			}

			.race-summary-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 0.75rem;
			}

			.race-summary-header h3 {
				color: var(--amber);
				font-size: 1.5rem;
				margin: 0;
			}

			.expand-icon {
				color: var(--amber);
				font-size: 1.25rem;
				transition: transform 0.3s;
			}

			.race-card[open] .expand-icon {
				transform: rotate(180deg);
			}

			.race-quick-info {
				display: flex;
				gap: 1rem;
			}

			.stat-badge,
			.trait-badge {
				padding: 0.25rem 0.75rem;
				border-radius: 6px;
				font-size: 0.9rem;
				font-weight: 600;
			}

			.stat-badge {
				background: var(--moss-green);
				color: var(--amber);
			}

			.trait-badge {
				background: var(--earth-brown);
				color: var(--cream);
			}

			.race-details {
				padding: 0 1.5rem 1.5rem;
			}

			.mechanics-box {
				background: var(--moss-green);
				padding: 1.5rem;
				border-radius: 8px;
				margin-bottom: 1rem;
			}

			.mechanics-box h4 {
				color: var(--amber);
				font-size: 1.25rem;
				margin-bottom: 1rem;
			}

			.mechanics-box ul {
				margin-left: 1.5rem;
			}

			.mechanics-box li {
				margin-bottom: 0.5rem;
			}

			.lore-expand {
				margin-top: 1rem;
			}

			.lore-expand summary {
				color: var(--leaf-green);
				cursor: pointer;
				font-weight: 600;
				padding: 0.5rem;
			}

			.lore-expand summary:hover {
				color: var(--amber);
			}

			.lore-content {
				padding: 1rem;
				color: var(--text-light);
			}

			.lore-content h5 {
				color: var(--leaf-green);
				margin: 1.5rem 0 0.75rem;
				font-size: 1.1rem;
			}

			.race-portrait-grid { display: flex; gap: 1.5rem; flex-wrap: wrap; margin: 1rem 0; }
			.race-portrait-item { text-align: center; }
			.race-portrait { width: 560px; height: 560px; object-fit: contain; border-radius: 8px; border: 2px solid var(--earth-brown); background: var(--forest-dark); }
			.race-portrait-label { color: var(--leaf-green); font-style: italic; margin-top: 0.5rem; font-size: 0.95rem; }

			.lore-content p {
				margin-bottom: 1rem;
			}

			/* Background Grid */
			.background-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1rem;
			}

			.bg-card {
				background: var(--forest-dark);
				border: 2px solid var(--earth-brown);
				border-radius: 12px;
				overflow: hidden;
			}

			.bg-card[open] {
				border-color: var(--leaf-green);
			}

			.bg-card summary {
				padding: 1.5rem;
				cursor: pointer;
				list-style: none;
			}

			.bg-card summary:hover {
				background: var(--moss-green);
			}

			.bg-card summary::-webkit-details-marker {
				display: none;
			}

			.bg-card summary h3 {
				color: var(--amber);
				font-size: 1.25rem;
				margin-bottom: 0.5rem;
			}

			.bg-tagline {
				color: var(--leaf-green);
				font-size: 0.9rem;
				font-style: italic;
			}

			.bg-details {
				padding: 0 1.5rem 1.5rem;
			}

			.bg-details p {
				margin-bottom: 0.75rem;
				font-size: 0.95rem;
			}

			/* Weapon Grid */
			.weapon-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			.weapon-summary-card {
				background: var(--forest-dark);
				border: 2px solid var(--earth-brown);
				border-radius: 12px;
				padding: 1.5rem;
				text-decoration: none;
				color: inherit;
				transition: all 0.3s ease;
				display: flex;
				flex-direction: column;
			}

			.weapon-summary-card:hover {
				border-color: var(--amber);
				transform: translateY(-4px);
				box-shadow: 0 6px 20px rgba(212, 162, 87, 0.3);
			}

			.weapon-icon {
				font-size: 3rem;
				text-align: center;
				margin-bottom: 1rem;
			}

			.weapon-summary-card h3 {
				color: var(--amber);
				font-size: 1.5rem;
				text-align: center;
				margin-bottom: 1rem;
			}

			.weapon-stats {
				display: flex;
				justify-content: center;
				gap: 0.5rem;
				margin-bottom: 1rem;
			}

			.weapon-role {
				color: var(--leaf-green);
				font-weight: 600;
				text-align: center;
				margin-bottom: 0.75rem;
			}

			.weapon-mechanic {
				font-size: 0.95rem;
				margin-bottom: 0.75rem;
			}

			.weapon-playstyle {
				font-size: 0.9rem;
				color: var(--text-light);
				margin-bottom: 1rem;
				flex-grow: 1;
			}

			.view-full {
				color: var(--amber);
				font-weight: 600;
				text-align: center;
				padding-top: 1rem;
				border-top: 1px solid var(--earth-brown);
			}

			/* Armor Table */
			.armor-table {
				width: 100%;
				border-collapse: collapse;
				background: var(--forest-dark);
				border-radius: 8px;
				overflow: hidden;
				margin-bottom: 1.5rem;
			}

			.armor-table th,
			.armor-table td {
				padding: 1rem;
				text-align: left;
				border-bottom: 1px solid var(--earth-brown);
			}

			.armor-table th {
				background: var(--moss-green);
				color: var(--amber);
				font-weight: 600;
			}

			.armor-table tr:last-child td {
				border-bottom: none;
			}

			.armor-details summary {
				color: var(--leaf-green);
				cursor: pointer;
				font-weight: 600;
				padding: 1rem;
			}

			.armor-details summary:hover {
				color: var(--amber);
			}

			.armor-sets {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
				gap: 1rem;
				padding: 1rem;
			}

			.armor-set-card {
				background: var(--forest-dark);
				padding: 1.5rem;
				border-radius: 8px;
				border: 2px solid var(--earth-brown);
			}

			.armor-set-card h4 {
				color: var(--amber);
				margin-bottom: 0.75rem;
			}

			/* Starting Gear */
			.starter-package {
				background: var(--forest-dark);
				padding: 2rem;
				border-radius: 12px;
				border: 2px solid var(--amber);
				margin-bottom: 1.5rem;
			}

			.starter-package h3 {
				color: var(--amber);
				font-size: 1.5rem;
				margin-bottom: 1rem;
			}

			.starter-list {
				list-style: none;
				margin: 0;
			}

			.starter-list li {
				padding: 0.5rem 0;
				font-size: 1.1rem;
			}

			.starter-kit-details summary {
				color: var(--leaf-green);
				cursor: pointer;
				font-weight: 600;
				padding: 1rem;
			}

			.starter-kit-details summary:hover {
				color: var(--amber);
			}

			.kit-content {
				padding: 1rem;
			}

			.kit-content h4 {
				color: var(--amber);
				font-size: 1.25rem;
				margin: 1.5rem 0 1rem;
			}

			.kit-content ul {
				margin-left: 1.5rem;
			}

			.kit-content li {
				margin-bottom: 0.5rem;
			}

			/* Final Calculations */
			.final-calc {
				border-color: var(--amber);
				border-width: 3px;
			}

			.calc-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
				gap: 1.5rem;
				margin-bottom: 2rem;
			}

			.calc-card {
				background: var(--forest-dark);
				padding: 2rem;
				border-radius: 12px;
				border: 2px solid var(--amber);
				text-align: center;
			}

			.calc-card h3 {
				color: var(--amber);
				font-size: 1.5rem;
				margin-bottom: 1rem;
			}

			.formula-display {
				background: var(--moss-green);
				padding: 1rem;
				border-radius: 8px;
				font-family: 'Courier New', monospace;
				font-weight: 700;
				font-size: 1.25rem;
				color: var(--amber);
				margin-bottom: 1rem;
			}

			.calc-note {
				font-size: 0.9rem;
				color: var(--leaf-green);
			}

			/* Ready Banner */
			.ready-banner {
				background: linear-gradient(135deg, var(--moss-green) 0%, var(--forest-green) 100%);
				padding: 3rem;
				border-radius: 12px;
				border: 3px solid var(--amber);
				text-align: center;
			}

			.ready-banner h3 {
				color: var(--amber);
				font-size: 2rem;
				margin-bottom: 1rem;
			}

			.ready-banner p {
				font-size: 1.25rem;
				margin-bottom: 2rem;
			}

			.next-links {
				display: flex;
				justify-content: center;
				gap: 1.5rem;
			}

			.btn-primary,
			.btn-secondary {
				padding: 1rem 2rem;
				border-radius: 8px;
				text-decoration: none;
				font-weight: 600;
				font-size: 1.1rem;
				transition: all 0.3s;
			}

			.btn-primary {
				background: var(--amber);
				color: var(--forest-dark);
			}

			.btn-primary:hover {
				background: var(--leaf-green);
				transform: translateY(-2px);
			}

			.btn-secondary {
				background: var(--forest-green);
				color: var(--amber);
				border: 2px solid var(--amber);
			}

			.btn-secondary:hover {
				background: var(--moss-green);
			}

			/* Responsive */
			@media (max-width: 768px) {
				.nav .container {
					flex-direction: column;
					gap: 1rem;
				}

				.nav-links {
					gap: 1rem;
					flex-wrap: wrap;
					justify-content: center;
				}

				.page-header h1 {
					font-size: 2rem;
				}

				.progress-tracker {
					flex-direction: column;
				}

				.creation-section {
					padding: 1.5rem;
				}

				.section-header {
					flex-direction: column;
					align-items: flex-start;
				}

				.background-grid,
				.weapon-grid {
					grid-template-columns: 1fr;
				}

				.next-links {
					flex-direction: column;
				}
			}

			/* Smooth Scrolling */
			html {
				scroll-behavior: smooth;
			}
		</style>
	</body>
</html>
