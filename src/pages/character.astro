---
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Character Creation - Untamed</title>
	</head>
	<body>
		<nav class="nav">
			<div class="container">
				<a href="/" class="logo">UNTAMED</a>
				<div class="nav-links">
					<a href="/rules">Rules</a>
					<a href="/quick-reference">Quick Reference</a>
					<a href="/character">Characters</a>
					<a href="/bestiary">Bestiary</a>
				</div>
			</div>
		</nav>

		<main>
			<div class="container">
				<div class="breadcrumb">
					<a href="/">← Back to Home</a>
				</div>

				<header class="page-header">
					<h1>Character Creation</h1>
					<p class="subtitle">Build your hunter in 5 steps</p>
				</header>

				<article class="content">
					<div class="progress-tracker">
						<div class="progress-step">
							<div class="step-number">1</div>
							<div class="step-label">Race</div>
						</div>
						<div class="progress-step">
							<div class="step-number">2</div>
							<div class="step-label">Background</div>
						</div>
						<div class="progress-step">
							<div class="step-number">3</div>
							<div class="step-label">Weapon</div>
						</div>
						<div class="progress-step">
							<div class="step-number">4</div>
							<div class="step-label">Armor</div>
						</div>
						<div class="progress-step">
							<div class="step-number">5</div>
							<div class="step-label">Starting Gear</div>
						</div>
					</div>

					<!-- STEP 1: RACE -->
					<section class="creation-section">
						<div class="section-header">
							<div class="section-number">1</div>
							<h2>Choose Your Race</h2>
						</div>

						<div class="race-overview">
							<table class="overview-table">
								<thead>
									<tr>
										<th>Race</th>
										<th>Stat Bonus</th>
										<th>Core Strength</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td><strong>Human</strong></td>
										<td>+1 Any</td>
										<td>Flexible</td>
									</tr>
									<tr>
										<td><strong>Dragonian</strong></td>
										<td>+1 INT</td>
										<td>Elemental Resistance</td>
									</tr>
									<tr>
										<td><strong>Trolian</strong></td>
										<td>+1 STR or DEX</td>
										<td>Survival & Fortitude</td>
									</tr>
									<tr>
										<td><strong>Thalorim</strong></td>
										<td>+1 CON or INS</td>
										<td>Aquatic Adaptation</td>
									</tr>
								</tbody>
							</table>
						</div>

						<div class="race-list">
							<!-- Human -->
							<details class="race-card">
								<summary>
									<div class="race-summary-header">
										<h3>Humans</h3>
										<span class="expand-icon">▼</span>
									</div>
									<div class="race-quick-info">
										<div class="stat-badge">+1 to any stat</div>
										<div class="trait-badge">Adaptable</div>
									</div>
								</summary>
								<div class="race-details">
									<div class="mechanics-box">
										<h4>Mechanics</h4>
										<ul>
											<li><strong>Stat Bonus:</strong> +1 to any stat of choice</li>
											<li><strong>Proficiencies:</strong> Choose 1 Skill</li>
											<li>
									<strong>Racial Trait — Adaptable:</strong> Once per round, when you spend Stamina on an Action or Reaction, you may gain one of the following benefits:
									<ul>
										<li>Gain +1 to the roll</li>
										<li>Move 5 ft without provoking opportunity attacks</li>
										<li>Reduce the Stamina cost by 1 (minimum 0)</li>
									</ul>
									You may use this a number of times equal to your Proficiency per Hunt.
								</li>
											<li><strong>Feature:</strong> Gain proficiency with one common tool.</li>
										</ul>
									</div>

									<details class="lore-expand">
										<summary>Expand Lore ▼</summary>
										<div class="lore-content">
											<p>Humans are the most abundant race in Oris Magna, known for their charm, adaptability, and resilience. Their civilizations have shaped the culture, politics, and traditions of the land, building sprawling kingdoms, republics, and trade hubs that thrive in every corner of Meridia.</p>

											<div class="race-portrait-grid">
														<div class="race-portrait-item"><img src="/races/Ephyra Coastal Hunter.png" alt="Ephyra Coastal Hunter" class="race-portrait" /><p class="race-portrait-label">Ephyra Coastal Hunter</p></div>
														<div class="race-portrait-item"><img src="/races/Human Hunter Desert.png" alt="Human Hunter Desert" class="race-portrait" /><p class="race-portrait-label">Human Hunter Desert</p></div>
														<div class="race-portrait-item"><img src="/races/Ormont Hunter Human.png" alt="Ormont Hunter Human" class="race-portrait" /><p class="race-portrait-label">Ormont Hunter Human</p></div>
													</div>
													<h5>Regional Humans</h5>
											<p><strong>Ephyra & The Aelmaris Isles 🌿🌊</strong> – The cultural and economic heartland of Meridia. Ephyrans are innovative traders, scholars, and warriors with olive to fair skin tones.</p>

											<p><strong>Ormont ⛰️</strong> – Hardy and disciplined people of the snow-capped peaks with fair skin and features sharpened by cold winds. Known for fortitude, craftsmanship, and warrior traditions.</p>

											<p><strong>Zerashan 🏜️</strong> – Desert dwellers defined by resilience and ingenuity, with darker skin tones shaped by the blazing sun. Fiercely independent nomadic traders and city dwellers.</p>
										</div>
									</details>
								</div>
							</details>

							<!-- Dragonian -->
							<details class="race-card">
								<summary>
									<div class="race-summary-header">
										<h3>Dragonians</h3>
										<span class="expand-icon">▼</span>
									</div>
									<div class="race-quick-info">
										<div class="stat-badge">+1 INT</div>
										<div class="trait-badge">Draconic Lineage</div>
									</div>
								</summary>
								<div class="race-details">
									<div class="mechanics-box">
										<h4>Mechanics</h4>
										<ul>
											<li><strong>Stat Bonus:</strong> +1 Intelligence</li>
											<li><strong>Proficiencies:</strong> Knowledge</li>
											<li>
									<strong>Racial Trait — Draconic Lineage:</strong> Choose one lineage. You gain its elemental resistance and rider.
									<table class="lineage-table">
										<thead><tr><th>Lineage</th><th>Scales</th><th>Resistance</th><th>Rider</th></tr></thead>
										<tbody>
											<tr><td><strong>Fire</strong></td><td>Red</td><td>Fire</td><td>Target gains Burned (1 stack)</td></tr>
											<tr><td><strong>Ice</strong></td><td>White</td><td>Cold</td><td>Target gains Chilled</td></tr>
											<tr><td><strong>Storm</strong></td><td>Violet</td><td>Lightning</td><td>If the target has already acted this round, deal +1 damage</td></tr>
											<tr><td><strong>Earth</strong></td><td>Green/Brown</td><td>Poison</td><td>Target cannot be pushed or repositioned until end of its next turn</td></tr>
											<tr><td><strong>Air</strong></td><td>Grey</td><td>Sonic</td><td>Move 5 ft after the attack without provoking opportunity attacks</td></tr>
											<tr><td><strong>Water</strong></td><td>Blue/Seafoam</td><td>Cold</td><td>You or an ally within 5 ft regain 1 Stamina</td></tr>
										</tbody>
									</table>
								</li>
								<li>
									<strong>Draconic Channeling:</strong> Once per turn, when you deal damage with an Attack or Technique, you may infuse it with your Draconic Element. If you do: apply your lineage’s elemental rider and spend +1 additional Stamina.
								</li>
											<li><strong>Feature:</strong> Read and recite Old Draconic sigils; you have advantage on Knowledge checks about draconic ruins.</li>
										</ul>
									</div>

									<details class="lore-expand">
										<summary>Expand Lore ▼</summary>
										<div class="lore-content">
											<p>Dragonians are the ancient descendants of dragons, remnants of a time when the great wyrms walked among mortals. Their lifespans stretch beyond 500 years, but their numbers are scarce.</p>

											<p>They bear the mark of their legendary ancestors—slitted reptilian eyes, pointed ears, and patches of hardened scales along their shoulders, arms, or chest.</p>

											<div class="race-portrait-grid">
														<div class="race-portrait-item"><img src="/races/Blue Dragonian.png" alt="Blue Dragonian" class="race-portrait" /><p class="race-portrait-label">Blue Dragonian</p></div>
														<div class="race-portrait-item"><img src="/races/Red Dragonian.png" alt="Red Dragonian" class="race-portrait" /><p class="race-portrait-label">Red Dragonian</p></div>
														<div class="race-portrait-item"><img src="/races/White Dragonian.png" alt="White Dragonian" class="race-portrait" /><p class="race-portrait-label">White Dragonian</p></div>
													</div>
													<h5>Regional Dragonians</h5>
											<p><strong>Ephyra & Aelmaris 🏛️🌊</strong> – Councilors, seers, and arcane scholars with dark, brown, or auburn hair and piercing eyes.</p>

											<p><strong>Ormont ❄️⛰️</strong> – Warriors and scholars with fair skin, white or platinum hair, and icy blue, grey, or silver eyes.</p>

											<p><strong>Zerashan 🏜️</strong> – In Zerashan’s harsh deserts, Dragonians are rare but highly respected. Known for intensity and precision, their deep bronze or ebony skin, striking eyes, and dark or ember-toned hair give them a formidable presence. Rather than inheriting power, Zerashani Dragonians are known for refining it through endurance and uncompromising resolve.</p>
										</div>
									</details>
								</div>
							</details>

							<!-- Trolian -->
							<details class="race-card">
								<summary>
									<div class="race-summary-header">
										<h3>Trolians</h3>
										<span class="expand-icon">▼</span>
									</div>
									<div class="race-quick-info">
										<div class="stat-badge">+1 STR or DEX</div>
										<div class="trait-badge">Wild Fortitude</div>
									</div>
								</summary>
								<div class="race-details">
									<div class="mechanics-box">
										<h4>Mechanics</h4>
										<ul>
											<li><strong>Stat Bonus:</strong> +1 Strength or +1 Dexterity</li>
											<li><strong>Proficiencies:</strong> Athletics</li>
											<li><strong>Racial Trait — Wild Fortitude:</strong> Advantage on CON saves vs Exhaustion, Poison, and Environmental Cold checks; advantage on Survival checks to endure cold.</li>
											<li><strong>Feature — Beast Signs:</strong> Advantage on Animal Handling checks when calming non-apex mammals.</li>
								<li>
									<strong>Lineage — Choose One:</strong>
									<ul>
										<li><strong>Highland — Anchored Frame:</strong> If you did not Move this turn, gain +1 AR until the start of your next turn.</li>
										<li><strong>Lowland — Flowstep:</strong> When you Move at least 10 ft on your turn, you may ignore difficult terrain for that movement.</li>
										<li><strong>Grove — Rooted Resilience:</strong> Once per round, when you fail a STR, DEX, or CON save, your next Reaction this round costs 1 less Stamina (minimum 0).</li>
									</ul>
								</li>
										</ul>
									</div>

									<details class="lore-expand">
										<summary>Expand Lore ▼</summary>
										<div class="lore-content">
											<p>Trolians are the most primal of the races, believed to be direct descendants of ancient beasts. With stout frames, immense strength, and animalistic features, they resemble the untamed forces of nature itself.</p>

											<p>Their lifespans stretch beyond 180 years, remaining in their prime for over a century.</p>

											<div class="race-portrait-grid">
														<div class="race-portrait-item"><img src="/races/Ironborn Trolian.png" alt="Ironborn Trolian" class="race-portrait" /><p class="race-portrait-label">Ironborn Trolian</p></div>
														<div class="race-portrait-item"><img src="/races/Lowland Trolian Hunter.png" alt="Lowland Trolian Hunter" class="race-portrait" /><p class="race-portrait-label">Lowland Trolian Hunter</p></div>
														<div class="race-portrait-item"><img src="/races/Grove Trolian.png" alt="Grove Trolian" class="race-portrait" /><p class="race-portrait-label">Grove Trolian</p></div>
													</div>
													<h5>Ancestral Bloodlines</h5>
											<p><strong>Ormont Trolians — Ironborn Lords ⛰️🛡️</strong> – Rulers of mountain citadels with fur-lined bodies, massive beards, and feral golden or deep blue eyes. Descended from wolves, bears, or mountain lions.</p>

											<p><strong>Lowland Trolians — The Bold & Untamed 🏞️⚒️</strong> – Shorter fur, sleeker frames, and keen tracking senses. Adventurous mercenaries, explorers, and craftsmen descended from foxes or jackals.</p>

											<p><strong>Grove Trolians — The Rootbound Kin 🌿</strong> – Some Trolians have bound themselves to the deep forests and ancient groves of Meridia, becoming guardians of the wild rather than conquerors of it. These Trolians bear the traits of great herbivores—stags, elk, boars, and other forest titans—standing tall with antlered crowns, dense earth-toned fur, and powerful, grounded builds.</p>

											<p>Unlike their mountain kin, Grove Trolians do not seek dominance through strength alone. They embody patience, balance, and controlled force, striking only when the natural order is threatened. They are deeply territorial, maintaining migration paths, hunting balances, and sacred groves. Those who overhunt or disrupt the land will find themselves stalked, tested, and—if necessary—driven out.</p>

											<p>In combat, Grove Trolians are reactive and deliberate, using terrain, positioning, and sudden bursts of power to overwhelm careless foes.</p>

											<h5>Culture</h5>
											<p>Strength & Honor Above All • The Hunt is Sacred • Steel & Stone • No King, Only Warlords • The Wildmoon Oath</p>
										</div>
									</details>
								</div>
							</details>

							<!-- Thalorim -->
							<details class="race-card">
								<summary>
									<div class="race-summary-header">
										<h3>Thalorim</h3>
										<span class="expand-icon">▼</span>
									</div>
									<div class="race-quick-info">
										<div class="stat-badge">+1 CON or INS</div>
										<div class="trait-badge">Tide Breath</div>
									</div>
								</summary>
								<div class="race-details">
									<div class="mechanics-box">
										<h4>Mechanics</h4>
										<ul>
											<li><strong>Stat Bonus:</strong> +1 Constitution or +1 Instinct</li>
											<li><strong>Proficiencies:</strong> Athletics or Survival</li>
											<li><strong>Movement:</strong> Swim speed equal to walking speed</li>
											<li><strong>Racial Trait — Tide Breath:</strong> Your Breath Timer is doubled while underwater.</li>
											<li><strong>Feature — Pressure Sense:</strong> Advantage on checks to detect underwater movement, large submerged creatures, or changes in depth/current. Never Surprised by aquatic creatures while submerged.</li>
										</ul>
									</div>

									<details class="lore-expand">
										<summary>Expand Lore ▼</summary>
										<div class="lore-content">
											<p>The Thalorim trace their ancestry to Thal'Meruun, an ancient underwater metropolis that collapsed long before recorded history. They survived, reshaped by rivers, tides, and the slow patience of water.</p>

											<div class="race-portrait-grid">
														<div class="race-portrait-item"><img src="/races/River Thalorim.png" alt="River Thalorim" class="race-portrait" /><p class="race-portrait-label">River Thalorim</p></div>
														<div class="race-portrait-item"><img src="/races/Aelmaris Thalorim.png" alt="Aelmaris Thalorim" class="race-portrait" /><p class="race-portrait-label">Aelmaris Thalorim</p></div>
													</div>
													<h5>Physiology</h5>
											<p>Amphibious humanoids with webbed fingers and toes, smooth skin in muted tones (slate, moss-green, pearl-grey, deep silt-blue), bioluminescent markings, and large reflective eyes.</p>

											<h5>Regional Communities</h5>
											<p><strong>Aelmaris Thalorim — Tidebound Traders 🌊</strong> – Powerful naval trade network controlling shipping routes and underwater resources.</p>

											<p><strong>River Thalorim — Floodplain Clans 🌿</strong> – Nomadic ferrymen, guides, and scouts along great rivers and wetlands.</p>

											<p><strong>Lake Thalorim — Stillwater Keepers 🌫️</strong> – Found along deep lakes and submerged basins, these Thalorim live slower, more deliberate lives. They are watchers rather than travelers—settling near deep waters where silence carries weight. Lake Thalorim track water levels, migration cycles, and disturbances beneath the surface over long periods. They speak less, act less, and wait longer—but when they do act, it is rarely without purpose. Among Thalorim, they are closest to the idea of “holding” rather than “flowing.”</p>

											<h5>Philosophy</h5>
											<p>Nothing truly ends — it changes state. Resistance is wasteful unless necessary. Survival is not cowardice if it preserves balance.</p>
										</div>
									</details>
								</div>
							</details>
						</div>
					</section>

					<!-- STEP 2: BACKGROUND -->
					<section class="creation-section">
						<div class="section-header">
							<div class="section-number">2</div>
							<h2>Choose Your Background</h2>
						</div>

						<div class="background-grid">
							<!-- Tribal Warrior -->
							<details class="bg-card">
								<summary>
									<h3>Tribal Warrior</h3>
									<p class="bg-tagline">STR/CON frontline</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 STR, +1 CON</p>
									<p><strong>Proficiencies:</strong> Athletics, Survival, Brute Force</p>
									<p><strong>Tool:</strong> Camp-Craft Kit</p>
									<p><strong>Trait — Part of a Tribe:</strong> When you Assist an ally on a Strength-based action, roll with advantage. Per Camp, when within reach of an ally, make a Strength check; on success, that ally gains +1 to their next roll.</p>
								</div>
							</details>

							<!-- Wanderer -->
							<details class="bg-card">
								<summary>
									<h3>Wanderer</h3>
									<p class="bg-tagline">DEX/INS scout</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 DEX, +1 INS</p>
									<p><strong>Proficiencies:</strong> Survival, Sense, Stealth</p>
									<p><strong>Tool:</strong> Navigator's Set</p>
									<p><strong>Trait — Nomadic Instincts:</strong> You always know the direction of the nearest settlement, fresh water, or safe shelter. Per Camp, reroll a failed Stealth or Survival check.</p>
								</div>
							</details>

							<!-- Apprentice Smith -->
							<details class="bg-card">
								<summary>
									<h3>Apprentice Smith</h3>
									<p class="bg-tagline">STR/INT craftsman</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 STR, +1 INT</p>
									<p><strong>Proficiencies:</strong> Trap Engineering, Heavy Trap Setup, Resource Identification</p>
									<p><strong>Tool:</strong> Smith's Apprentice Tools</p>
									<p><strong>Trait — Battle-Ready Smith:</strong> Craft/modify/repair weapons or armor at smithy during Downtime. Per Camp, after examining a monster's body, make Knowledge (INT); on success GM identifies a weak point.</p>
								</div>
							</details>

							<!-- Scholar -->
							<details class="bg-card">
								<summary>
									<h3>Scholar</h3>
									<p class="bg-tagline">INT/INS investigator</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 INT, +1 INS</p>
									<p><strong>Proficiencies:</strong> Knowledge, First Aid, Resource Identification</p>
									<p><strong>Tool:</strong> Cartographer's Pouch</p>
									<p><strong>Trait — Well Read:</strong> Advantage on Knowledge (INT) checks to decipher ancient texts, runes, or records. Per Hunt, after 2 rounds observing, learn one: resistance, part-break threshold, or telegraph.</p>
								</div>
							</details>

							<!-- Beast Tamer -->
							<details class="bg-card">
								<summary>
									<h3>Beast Tamer</h3>
									<p class="bg-tagline">INS/CHA tracker</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 INS, +1 CHA</p>
									<p><strong>Proficiencies:</strong> Creature Analysis, Sense, Animal Handling</p>
									<p><strong>Tool:</strong> Bait & Lure Kit</p>
									<p><strong>Trait — Whisperer of the Wilds:</strong> All checks with a mount at advantage. Per Camp, make free Instinct (INS) check to predict a visible creature's next attack or movement.</p>
								</div>
							</details>

							<!-- Sailor -->
							<details class="bg-card">
								<summary>
									<h3>Sailor</h3>
									<p class="bg-tagline">DEX/CON seafarer</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 DEX, +1 CON</p>
									<p><strong>Proficiencies:</strong> Grapple, Deftness, Handling</p>
									<p><strong>Tool:</strong> Rope & Rigging Kit</p>
									<p><strong>Trait — Born of the Sea:</strong> Expert swimmer, no water movement penalties, extended breath. Per Hunt, automatically keep balance on unstable terrain for 1 round without check.</p>
								</div>
							</details>

							<!-- Merchant Heir -->
							<details class="bg-card">
								<summary>
									<h3>Merchant Heir</h3>
									<p class="bg-tagline">CHA/INS trader</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 CHA, +1 INS</p>
									<p><strong>Proficiencies:</strong> Negotiation, Resource Identification, Sense</p>
									<p><strong>Tool:</strong> Signal & Dye Kit</p>
									<p><strong>Trait — Children of the Coin:</strong> Per Downtime, call in merchant favor: 10-20% discount, rare material access, or rush-craft order. Instantly appraise monster materials.</p>
								</div>
							</details>

							<!-- Priest of the Wild -->
							<details class="bg-card">
								<summary>
									<h3>Priest of the Wild</h3>
									<p class="bg-tagline">CHA/INT mystic</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 CHA, +1 INT</p>
									<p><strong>Proficiencies:</strong> First Aid, Animal Handling, Knowledge</p>
									<p><strong>Tool:</strong> Cook's Pack</p>
									<p><strong>Trait — Wild Rites:</strong> Rites over slain monsters improve harvest quality. Per Hunt, attempt to Pacify a lesser beast (Tier 1) within 20 ft.</p>
								</div>
							</details>

							<!-- Scavenger -->
							<details class="bg-card">
								<summary>
									<h3>Scavenger</h3>
									<p class="bg-tagline">DEX/CHA opportunist</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 DEX, +1 CHA</p>
									<p><strong>Proficiencies:</strong> Stealth, Deftness, Deception</p>
									<p><strong>Tool:</strong> Boneworking Kit</p>
									<p><strong>Trait — Opportunist's Instinct:</strong> Proficient in Sense when rummaging. Per Hunt, roll Stealth with advantage when evading detection.</p>
								</div>
							</details>

							<!-- Alchemist -->
							<details class="bg-card">
								<summary>
									<h3>Alchemist</h3>
									<p class="bg-tagline">INT/CON scientist</p>
								</summary>
								<div class="bg-details">
									<p><strong>Stat Bonuses:</strong> +2 INT, +1 CON</p>
