			.creature-title h3 { color: var(--amber); font-size: 2rem; margin-bottom: 0.25rem; }
			.creature-tagline { color: var(--leaf-green); font-style: italic; font-size: 1.1rem; }

			.creature-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.75rem; }
			.creature-portrait { width: 420px; height: 420px; object-fit: contain; border-radius: 8px; border: 2px solid var(--earth-brown); background: var(--forest-dark); }

			.tier-badge { padding: 0.5rem 1rem; border-radius: 6px; font-weight: 600; font-size: 0.9rem; }
			.tier-badge.tier-0 { background: var(--earth-brown); color: var(--cream); }
			.tier-badge.tier-1 { background: var(--moss-green); color: var(--amber); }
			.tier-badge.tier-2 { background: var(--forest-green); color: var(--amber); border: 2px solid var(--amber); }
			.tier-badge.tier-3 { background: #5c2000; color: #ffcc66; border: 2px solid #ffcc66; }
			.tier-badge.tier-4 { background: #3a0000; color: #ff8c42; border: 2px solid #ff8c42; }
			.tier-badge.tier-5 { background: #1a0a2e; color: #cc88ff; border: 2px solid #cc88ff; }

			.creature-info-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; padding: 1rem; background: var(--forest-dark); border-radius: 8px; }
			.info-item { font-size: 0.95rem; }
			.info-item strong { color: var(--amber); }

			.creature-section { margin-bottom: 2rem; }
			.creature-section h4 { color: var(--leaf-green); font-size: 1.3rem; margin-bottom: 1rem; }
			.creature-section p { margin-bottom: 1rem; }
			.creature-section ul { margin-left: 1.5rem; margin-bottom: 1rem; }
			.creature-section li { margin-bottom: 0.5rem; }

			.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
			.stat-block { background: var(--forest-dark); padding: 1rem; border-radius: 8px; }
			.stat-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--earth-brown); }
			.stat-row:last-child { border-bottom: none; }
			.stat-row span { color: var(--leaf-green); }
			.stat-row strong { color: var(--amber); }

			.ability-list { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1rem; }
			.ability { background: var(--forest-dark); padding: 1.5rem; border-radius: 8px; border-left: 3px solid var(--amber); }
			.ability-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
			.ability-header strong { color: var(--amber); font-size: 1.1rem; }
			.ability-cost { background: var(--moss-green); padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.85rem; color: var(--cream); }
			.ability p { margin-bottom: 0.5rem; }
			.ability p:last-child { margin-bottom: 0; }
			.ability ul { margin-left: 1.5rem; margin-top: 0.5rem; }

			.special-trait { background: var(--moss-green); padding: 1.5rem; border-radius: 8px; margin-top: 1rem; }
			.special-trait strong { color: var(--amber); display: block; margin-bottom: 0.5rem; }
			.special-trait p { margin: 0; }

			.loot-table { width: 100%; border-collapse: collapse; background: var(--forest-dark); border-radius: 8px; overflow: hidden; }
			.loot-table th, .loot-table td { padding: 1rem; text-align: left; border-bottom: 1px solid var(--earth-brown); }
			.loot-table th { background: var(--moss-green); color: var(--amber); font-weight: 600; }
			.loot-table tr:last-child td { border-bottom: none; }

			.crafting-recipe { background: var(--forest-dark); padding: 1rem; border-radius: 8px; margin-bottom: 0.75rem; border-left: 3px solid var(--leaf-green); }
			.crafting-recipe:last-child { margin-bottom: 0; }
			.crafting-recipe strong { color: var(--leaf-green); display: block; margin-bottom: 0.5rem; }
			.crafting-recipe p { margin: 0; }

			.crafting-list { display: flex; flex-direction: column; gap: 0.75rem; }

			@media (max-width: 768px) {
				.nav .container { flex-direction: column; gap: 1rem; }
				.nav-links { gap: 1rem; flex-wrap: wrap; justify-content: center; }
				.page-header h1 { font-size: 2rem; }
				.creature-header { flex-direction: column; gap: 1rem; }
				.creature-info-bar { grid-template-columns: 1fr; }
				.stats-grid { grid-template-columns: 1fr; }
			}

			html { scroll-behavior: smooth; }
		</style>
	</body>
</html>
